{
  "info": {
    "_postman_id": "b7b8f7a4-7c6c-4c69-9c4b-1d8c5a9f7d21",
    "name": "Product Management API",
    "description": "Postman collection for the JWT secured Product Management API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Soumik\",\n  \"lastName\": \"Das\",\n  \"email\": \"soumik@example.com\",\n  \"password\": \"StrongPass@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/registerUser",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "registerUser"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"soumik@example.com\",\n  \"password\": \"StrongPass@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Samsung Galaxy S25\",\n  \"description\": \"Latest Samsung flagship smartphone\",\n  \"price\": 79999.99,\n  \"quantity\": 20,\n  \"category\": \"Electronics\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/createProduct",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "createProduct"]
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Samsung Galaxy S25\",\n  \"description\": \"Updated product description\",\n  \"price\": 82999.99,\n  \"quantity\": 18,\n  \"category\": \"Electronics\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/updateProduct/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "updateProduct", "1"]
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/deleteProduct/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "deleteProduct", "1"]
            }
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/getProduct/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "getProduct", "1"]
            }
          }
        },
        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/getProducts?page=0&size=10&sortBy=id&direction=asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "getProducts"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "id"
                },
                {
                  "key": "direction",
                  "value": "asc"
                }
              ]
            }
          }
        },
        {
          "name": "Search",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/search?keyword=Samsung&page=0&size=10&sortBy=id&direction=asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "search"],
              "query": [
                {
                  "key": "keyword",
                  "value": "Samsung"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "id"
                },
                {
                  "key": "direction",
                  "value": "asc"
                }
              ]
            }
          }
        },
        {
          "name": "Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/category?category=Electronics&page=0&size=10&sortBy=id&direction=asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "category"],
              "query": [
                {
                  "key": "category",
                  "value": "Electronics"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "id"
                },
                {
                  "key": "direction",
                  "value": "asc"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
